;
; BIND data file for local loopback interface
;
$TTL    604800
home.blrobinson.uk.    IN    SOA    dns.home.blrobinson.uk. home.blrobinson.uk. (
                  2        ; Serial
             604800        ; Refresh
              86400        ; Retry
            2419200        ; Expire
             604800 )    ; Negative Cache TTL
;
home.blrobinson.uk.    IN    NS    dns.k8s.home.blrobinson.uk.
home.blrobinson.uk.    IN    MX    10 mail.k8s.blrobinson.uk.

web.k8s     IN A 10.0.3.100
web.k8s     IN AAAA 2a06:61c2:27ae:2::0003
*.k8s       IN A 10.0.3.101
*.k8s       IN AAAA 2a06:61c2:27ae:2::0004
adguard.k8s IN A 10.0.3.102
adguard.k8s IN AAAA 2a06:61c2:27ae:2::0002
dns         IN A 10.0.3.103
dns         IN AAAA 2a06:61c2:27ae:2::0001
dns.k8s     IN A 10.0.3.103
dns.k8s     IN AAAA 2a06:61c2:27ae:2::0001
unifi.k8s   IN A 10.0.3.104
mail.k8s    IN A 10.0.3.104
; mail.k8s    IN AAAA 2a06:61c2:27ae:2::0005  ; Mailu does not listen on IPv6 (https://github.com/Mailu/Mailu/issues/2293)
shell.k8s   IN A 10.0.3.105
shell.k8s   IN AAAA 2a06:61c2:27ae:2::0006

